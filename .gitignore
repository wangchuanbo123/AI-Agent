# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and package outputs
build/
dist/
*.egg-info/
.eggs/
*.egg

# Test, coverage, and type-check caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
