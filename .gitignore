.ruff_cache/
.pyre/
.tox/

# Local environment variables and secrets
.env
.env.*
!.env.example

# Local MCP config; keep example files tracked
mcp_servers.json
!mcp_servers.example.json

# Logs and temporary files
*.log
logs/
tmp/
temp/
*.tmp

# IDE / editor settings
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini
